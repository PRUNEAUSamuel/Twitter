{% extends 'base.html.twig' %} 



{% block body %}
    <div class="container mt-5">
        <h1 class="text-center text-white mb-4">Modifier votre profil</h1>

        {% for label, messages in app.flashes %}
            <div class="alert alert-{{ label }}">
                {% for message in messages %}
                    <p>{{ message }}</p>
                {% endfor %}
            </div>
        {% endfor %}

        <div class="card shadow-sm p-4">
            <div class="row">
                <div class="col-md-4 text-center">
                    {# Affichage de la photo de profil actuelle #}
                    <div class="profile-picture mb-3">
                        {% if user.profilePicture %}
                            <img src="{{ asset('uploads/profile_pictures/' ~ user.profilePicture) }}" alt="Photo de profil" class="img-fluid rounded-circle border-none" width="250" height="250">
                        {% else %}
                            <img src="{{ asset('images/default-profile.png') }}" alt="Photo de profil" class="img-fluid rounded-circle border-none" width="150">
                        {% endif %}
                    </div>
                    {# Formulaire de téléchargement de la photo #}
                    <form method="POST" action="{{ path('app_profile_edit') }}" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label for="profile_picture" class="form-label text-white">Modifier la photo de profil</label>
                            <input type="file" id="profile_picture" name="profile_picture" class="form-control text-white"  style="background-color: #343a40; border: 1px solid #6c757d;">
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Changer la photo</button>
                    </form>
                </div>

                <div class="col-md-8">
                    {{ form_start(form) }}

                    <div class="mb-3">
                        {{ form_label(form.username, 'Nom d\'utilisateur', {'label_attr': {'class': 'form-label text-white'}}) }}
                        {{ form_widget(form.username, {'attr': {'class': 'form-control text-white'}}) }}
                        <div class="text-danger">
                            {{ form_errors(form.username) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.email, 'Adresse e-mail', {'label_attr': {'class': 'form-label text-white'}}) }}
                        {{ form_widget(form.email, {'attr': {'class': 'form-control text-white'}}) }}
                        <div class="text-danger">
                            {{ form_errors(form.email) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.password, 'Mot de passe', {'label_attr': {'class': 'form-label text-white'}}) }}
                        {{ form_widget(form.password, {'attr': {'class': 'form-control text-white'}}) }}
                        <div class="text-danger">
                            {{ form_errors(form.password) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.Confirm_password, 'Confirmer le mot de passe', {'label_attr': {'class': 'form-label text-white'}}) }}
                        {{ form_widget(form.Confirm_password, {'attr': {'class': 'form-control text-white'}}) }}
                        <div class="text-danger">
                            {{ form_errors(form.Confirm_password) }}
                        </div>
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-primary w-100">Mettre à jour</button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}