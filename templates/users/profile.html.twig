{% extends 'base.html.twig' %}

{% block body %}
<div class="profile-container">
        <h2>Profil de {{ user.username }}</h2>

        <div class="user-info">
            <h3>Informations personnelles</h3>
            <p><strong>Nom :</strong> {{ user.username }}</p>
            <p><strong>Email :</strong> {{ user.email }}</p>
            {# Ajouter d'autres informations personnelles si nécessaire #}
        </div>

        <div class="tweets-section">
            <h3>Mes Tweets</h3>

            {% if tweets is empty %}
                <p>Vous n'avez pas encore publié de tweet.</p>
            {% else %}
                <ul>
                    {% for tweet in tweets %}
                        <li>
                            <p>{{ tweet.content }}</p>
                            <p><small>Publié le {{ tweet.createdAt|date('d/m/Y H:i') }}</small></p>

                            {# Boutons pour modifier ou supprimer un tweet #}
                            <a href="{{ path('app_tweet_edit', {'id': tweet.id}) }}" class="btn btn-warning">Modifier</a>

                            <form method="post" action="{{ path('app_tweet_delete', {'id': tweet.id}) }}" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tweet.id) }}">
                                <button type="submit" class="btn btn-danger">Supprimer</button>
                            </form>
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>

        {# Ajouter un bouton pour créer un nouveau tweet #}
        <div class="new-tweet">
            <a href="{{ path('app_tweet_new') }}" class="btn btn-primary">Nouveau Tweet</a>
        </div>
    </div>

    {# Ajoute des styles spécifiques si nécessaire #}
    <style>
        .profile-container {
            margin: 20px;
        }

        .user-info, .tweets-section {
            margin-bottom: 30px;
        }

        .tweets-section ul {
            list-style-type: none;
            padding: 0;
        }

        .tweets-section li {
            margin: 10px 0;
            padding: 10px;
            border: 1px solid #ccc;
        }

        .new-tweet {
            margin-top: 20px;
        }

        .btn {
            margin-right: 10px;
        }
    </style>

{% endblock %}

