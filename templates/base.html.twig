<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
            <link href="{{ asset('css/big-dark-mode.css') }}" rel="stylesheet">
            <link rel="stylesheet" href="{{ asset('css/custom.css') }}">
            <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
        {% endblock %}

        {% block javascripts %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body data-bs-theme="dark-oled" class="text-white">
        <nav class="navbar navbar-expand-lg bg-black border-bottom border-secondary">
            <div class="container-fluid">
                <div class="w-100 d-flex align-items-center" id="navbarSupportedContent">
                    <ul class="navbar-nav me-auto fw-bold flex-row align-items-end">
                        <li class="nav-item mx-3">
                            <a class="nav-link text-white" href="{{ path('app_tweets_index') }}">Accueil</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-white" href="{{ path('app_profile') }}">Profil</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-white" href="{{ path('app_tweet_new') }}">Publier</a>
                        </li>
                        <li class="nav-item mx-3">
                            {% if app.user %}
                                <a id="logout-link" class="nav-link text-white" href="">Déconnexion</a>
                                <form id="logout-form" action="{{ path('app_logout') }}" method="POST" style="display: none;">
                                    {{ csrf_token('logout') }}
                                </form>
                                <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
                                <script type="text/javascript">
                                    document.getElementById("logout-link").addEventListener("click", function(event) {
                                        event.preventDefault();
                                        Swal.fire({
                                            title: 'Êtes-vous sûr de vouloir vous déconnecter ?',
                                            text: 'Vous serez déconnecté de votre session.',
                                            icon: 'warning',
                                            showCancelButton: true,
                                            confirmButtonText: 'Déconnexion',
                                            cancelButtonText: 'Annuler',
                                            customClass: {
                                                popup: 'border border-secondary bg-black text-white', // Personnalisation de la popup
                                                confirmButton: 'btn btn-light text-black fw-bold', // Personnalisation du bouton de confirmation
                                                cancelButton: 'btn btn-black text-white fw-bold border-secondary' // Personnalisation du bouton d'annulation
                                            },
                                            // Animations
                                            showClass: {
                                                popup: 'animate__animated animate__fadeInDown'
                                            },
                                            hideClass: {
                                                popup: 'animate__animated animate__fadeOutUp'
                                            }
                                        }).then((result) => {
                                            if (result.isConfirmed) {
                                                // Si l'utilisateur confirme, soumettre le formulaire de déconnexion
                                                document.getElementById("logout-form").submit();
                                            }
                                        });
                                    });
                                </script>
                            {% else %}
                                <a class="nav-link text-white" href="{{ path('app_login') }}">Connexion</a>
                            {% endif %}
                        </li>
                    </ul>
                    <form class="d-flex" role="search">
                        <div class="form-floating mx-1">
                            <input type="search" class="form-control me-2 border-secondary text-white" id="floatingSearch" placeholder="" aria-label="Search">
                            <label for="floatingSearch">Mot clé</label>
                        </div>
                        <button class="btn btn-outline-success" type="submit">Rechercher</button>
                    </form>
                </div>
            </div>
        </nav>
    </body>
    {% block body %}{% endblock %}
</html>