{% extends 'base.html.twig' %}

{% block title %}Suppression d'un Tweet{% endblock %}

{% block body %}

<main class="d-flex flex-column justify-content-center align-items-center mt-5 text-center">

<h2>Êtes-vous sûr de vouloir supprimer ce tweet ?</h2>

<p>Contenu du tweet : {{tweet.content}}</p>
<p>Publié le : {{tweet.createdAt|date('d/m/Y H:i')}}</p>

<form method="post" action="{{ path('app_tweet_delete', {'id': tweet.id}) }}">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tweet.id) }}">
    <button type= submit class="btn btn-danger">Oui, Supprimer</button>
</form>

<a href="{{path('app_profile') }}" class="btn btn-secondary">Annuler</a>



</main>





{% endblock body %}