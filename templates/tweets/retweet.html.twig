{% extends 'base.html.twig' %}

{% block title %}Retweeter{% endblock %}

{% block body %}
<main class="w-50 mx-auto">

    <section class="border border-1 border-secondary p-4">
        <h2 class="text-center">Retweeter</h2>

        <form action="{{ path('app_tweet_retweet', { id: tweet.id }) }}" method="POST">
            <div class="mb-3">
                <textarea 
                    class="form-control" 
                    name="content" 
                    rows="3" 
                    placeholder="Ajoutez votre commentaire ici..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Retweeter</button>
        </form>
    </section>

    <section class="border border-1 border-secondary p-4 mt-4">
        <h4>Tweet original :</h4>
        <p><strong>{{ tweet.user.username }}</strong> - {{ tweet.createdAt|date('d/m/Y H:i') }}</p>
        <p class="text-break">{{ tweet.content }}</p>
    </section>

</main>
{% endblock %}
