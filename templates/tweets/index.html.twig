{% extends 'base.html.twig' %}

{% block title %}Twitter > X
{% endblock %}


{% block javascripts %}
	<script src="{{ asset('js/like.js') }}" defer></script>
{% endblock %}


{% block body %}

	<main class="w-50  mx-auto">

		<section class="border border-1 border-secondary text-center p-5">
			<a class="text-decoration-none text-white" href="{{path('app_tweets_index')}}">
				<h2>Twitter > X</h2>
			</a>
		</section>

		<section class="border border-1 border-secondary text-center p-2">
			<a class="text-decoration-none text-white" href="{{ path('app_tweet_new') }}">Poster un Tweet</a>
		</section>

		<section>
			{% if tweets is empty %}
				<div class="border border-1 border-secondary text-center">
					<p>Aucun Tweet pour le moment ! N'hésites pas à en faire un !
					</p>
				</div>
			{% else %}
				{% for tweet in tweets %}
					<div class="border border-1 border-secondary p-2 d-flex flex-column">
						<span>
							{{ tweet.user.username }}
							-
							{{ tweet.createdAt ? tweet.createdAt|date('d/m/Y H:i:s') : '' }}
							{# {{ tweet.updateAt ? tweet.updateAt|date('d/m/Y H:i:s') : '' }} #}
						</span>
						<p class="p-2 mt-3 mb-1 text-break">{{ tweet.content }}</p>

						<div class="comments mt-4">
							{% if tweet.comments is not empty %}
								<h4 class="mt-4">Commentaires :</h4>
								<!-- Bouton pour afficher/masquer les commentaires -->
								<button class="btn btn-outline-secondary btn-sm mb-3" onclick="toggleComments({{ tweet.id }})">
									Afficher les commentaires
								</button>
								<div id="comments-{{ tweet.id }}" class="comments-list" style="display: none;">
									{% for comment in tweet.comments %}
										<div class="comment  mb-4 p-3 border rounded">
											<strong>{{ comment.user ? comment.user.username : 'Utilisateur inconnu' }}
												:</strong>
											{{ comment.content }}
											<p class="mt-2 mb-3">{{ comment.content }}</p>
											<!-- Lien pour répondre au commentaire -->
											<a href="{{ path('app_comment_new', {'tweetId': tweet.id, 'parentCommentId': comment.id}) }}" class="btn btn-sm btn-outline-primary">Répondre</a>

											<div class="replies mt-3 ms-4" style="margin-left: 20px;">
												{% include 'comment/_replies.html.twig' with {'comment': comment, 'tweet': tweet} %}
											</div>
										</div>
									{% endfor %}
								</div>
							{% else %}
								<p>Aucun commentaire pour ce tweet.</p>
							{% endif %}
						</div>
						<!-- Formulaire pour ajouter un commentaire -->
						{% if app.user %}
							<a href="{{ path('app_comment_new', {'tweetId': tweet.id}) }}" class="btn btn-sm w-25 border-white fw-bold comment-btn ">
								<span>Commenter</span>
								<i class="fa-regular fa-comment"></i>
							</a>
						{% else %}
							<p>Vous devez être connecté pour commenter.</p>
						{% endif %}
						<div class="align-self-end d-flex">
							<button onclick="window.location.href='#'" {% if not app.user %} disabled {% endif %} class="btn border-white fw-bold comment-btn bouton">
								<span>1</span>
								<i class="fa-regular fa-comment"></i>
							</button>
							<button onclick="window.location.href='{{ path('app_tweet_retweet', { id: tweet.id }) }}'" {% if not app.user %} disabled {% endif %} class="btn btn-outline-secondary fw-bold rt-btn bouton mx-2">
								<span>{{ tweet.getRetweetCount() }}</span>
								<i class="fa-solid fa-arrows-rotate"></i>
							</button>
							<button class="btn btn-outline-danger fw-bold like-btn bouton" {% if not app.user %} disabled {% endif %} id="like-button-{{ tweet.id }}" data-tweet-id="{{ tweet.id }}">
								<div class="like-div-{{ tweet.id }}">
									<span id="likes-count-{{ tweet.id }}">{{ tweet.likes | length }}</span>
									{% if app.user and tweet.likes|filter(like => like.user.id == app.user.id)|length > 0 %}
										<i class="like-img-{{ tweet.id }} fas fa-heart"></i>
									{% else %}
										<i class="like-img-{{ tweet.id }} far fa-heart"></i>
									{% endif %}
								</div>
							</button>
						</div>
					</div>
				{% endfor %}
			{% endif %}
		</section>
	</main>

{% endblock %}
