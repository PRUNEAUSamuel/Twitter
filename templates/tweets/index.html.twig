{% extends 'base.html.twig' %}

{% block title %}Tweets index{% endblock %}

{% block body %}
    <h1>Tweets index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Tweet</th>
                <th>Auteur</th>
                <th>Créé le</th>
                <th>Modifié le</th>
            </tr>
        </thead>
        <tbody>
        {% for tweet in tweets %}
            <tr>
                <td>{{ tweet.content }}</td>
                <td>{{ tweet.user.username }}</td>
                <td>{{ tweet.createdAt ? tweet.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ tweet.updateAt ? tweet.updateAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_tweet_new') }}">Create new</a>
{% endblock %}
