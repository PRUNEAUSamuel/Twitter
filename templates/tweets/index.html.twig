{% extends 'base.html.twig' %}

{% block title %}Twitter>X
{% endblock %}

{% block body %}

	<main class="w-50 m-auto">

		<section class="border border-1 border-secondary text-center p-3">

			<a class="text-decoration-none text-white" href="{{path('app_tweets_index')}}">
				<h2>Twitter > X</h2>
			</a>

		</section>

		<section class="border border-1 border-secondary text-center">
			<a class="text-decoration-none text-white" href="{{ path('app_tweet_new') }}">Poster un Tweet</a>
		</section>

		<section>
			{% if tweets is empty %}
				<div class="border border-1 border-secondary text-center">
					<span>Aucun Tweet pour le moment ! N'hésites pas à en faire un !
					</span>
				</div>
			{% else %}
				{% for tweet in tweets %}
					<div class="border border-1 border-secondary">
						<span class="text-start">
							{{ tweet.user.username }}
							-
							{{ tweet.createdAt ? tweet.createdAt|date('d/m/Y H:i:s') : '' }}
						{# - #}
							{# {{ tweet.updateAt ? tweet.updateAt|date('Y-m-d H:i:s') : '' }} #}
						</span>
						<p class="text-center">{{ tweet.content }}</p>
					</div>
				{% endfor %}
			{% endif %}
		</section>
	</main>

{% endblock %}
