{% extends 'base.html.twig' %}

{% block title %}Twitter > X
{% endblock %}

{% block javascripts %}
	<script src="{{ asset('js/like.js') }}" defer></script>
{% endblock %}


{% block body %}
	<main class="w-75 mx-auto d-flex flex-column align-items-center">
		<h1 class="my-5">Twitter > X</h1>
		<section class="w-75">
			{% if allTweets is empty %}
				<div class="border border-1 border-secondary text-center">
					<p>Aucun Tweet pour le moment ! N'hésites pas à en faire un !</p>
				</div>
			{% else %}
				{% for allTweet in allTweets %}
					<div class="border border-1 border-secondary p-2 my-3 d-flex flex-column rounded-2">
						{% if allTweet.isRetweet() %}
							<span>
								<span class="pe-2">
									{% if app.user.profilePicture %}
										<img src="{{ asset('uploads/profile_pictures/' ~ app.user.profilePicture) }}" alt="Photo de profil" class="rounded-circle" width="40" height="40">
									{% else %}
										<i class="fas fa-user-circle" style="font-size: 30px;"></i>
									{% endif %}
								</span>
								{{ allTweet.user.username }}
								-
								{{ allTweet.createdAt|date('d/m/Y H:i:s') }}
							</span>
							<p class="p-2 t-1 mb-2 text-break">{{ allTweet.content }}</p>
							<div class="border border-1 border-secondary p-2 m-2 rounded-1">
								<span>
									<span class="pe-2">
										{% if app.user.profilePicture %}
											<img src="{{ asset('uploads/profile_pictures/' ~ app.user.profilePicture) }}" alt="Photo de profil" class="rounded-circle" width="40" height="40">
										{% else %}
											<i class="fas fa-user-circle" style="font-size: 30px;"></i>
										{% endif %}
									</span>

									{% if allTweet.tweet is null %}
										<p>Ce tweet a été supprimé</p>
									{% else %}

										{{ allTweet.tweet.user.username }}
										-
										{{ allTweet.tweet.createdAt|date('d/m/Y H:i:s') }}
									</span>
									<p class="p-2 t-1 mb-2 text-break">{{ allTweet.tweet.content }}</p>
									
								</div>

								<div class="justify-content-end d-flex">
									<button onclick="window.location.href='#'" {% if not app.user %} disabled {% endif %} class="btn border-white fw-bold comment-btn bouton">
										<span>1</span>
										<i class="fa-regular fa-comment"></i>
									</button>
									<button onclick="window.location.href='{{ path('app_tweet_retweet', { id: allTweet.tweet.id }) }}'" {% if not app.user %} disabled {% endif %} class="btn btn-outline-secondary fw-bold rt-btn bouton mx-2">
										<span>{{ allTweet.tweet.getRetweetCount() }}</span>
										<i class="fa-solid fa-arrows-rotate"></i>
									</button>
									<button class="btn btn-outline-danger fw-bold like-btn bouton" {% if not app.user %} disabled {% endif %} id="like-button-{{ allTweet.id }}" data-tweet-id="{{ allTweet.id }}">
										<div class="like-div-{{ allTweet.id }}">
											<span id="likes-count-{{ allTweet.id }}">{{ allTweet.tweet.likes | length }}</span>
											{% if app.user and allTweet.tweet.likes|filter(like => like.user.id == app.user.id)|length > 0 %}
												<i class="like-img-{{ allTweet.id }} fas fa-heart"></i>
											{% else %}
												<i class="like-img-{{ allTweet.id }} far fa-heart"></i>
											{% endif %}
										</div>
									</button>
									{% endif %}
								</div>
							{% else %}
								<span>
									<span class="pe-2">
										{% if app.user.profilePicture %}
											<img src="{{ asset('uploads/profile_pictures/' ~ app.user.profilePicture) }}" alt="Photo de profil" class="rounded-circle" width="40" height="40">
										{% else %}
											<i class="fas fa-user-circle" style="font-size: 30px;"></i>
										{% endif %}
									</span>
									{{ allTweet.user.username }}
									-
									{{ allTweet.createdAt|date('d/m/Y H:i:s') }}
								</span>
								<p class="p-2 mt-1 mb-2 text-break">{{ allTweet.content }}</p>
								<div class="comments">
									{% if allTweet.comments is not empty %}
										<h4 class="mt-4">Commentaires :</h4>
										<!-- Bouton pour afficher/masquer les commentaires -->
										<button class="btn btn-outline-secondary btn-sm mb-3" onclick="toggleComments({{ allTweet.id }})">
											Afficher les commentaires
										</button>
										<div id="comments-{{ allTweet.id }}" class="comments-list" style="display: none;">
											{% for comment in allTweet.comments %}
												<div class="comment mb-4 p-3 border rounded">
													<strong>{{ comment.user ? comment.user.username : 'Utilisateur inconnu' }}:</strong>
													{{ comment.content }}

													<!-- Lien pour répondre au commentaire -->
													<a href="{{ path('app_comment_new', {'tweetId': allTweet.id, 'parentCommentId': comment.id}) }}" class="btn btn-sm btn-outline-primary">
														Répondre</a>
													{# Bouton pour modifier le commentaire #}
													{% if app.user and app.user == comment.user %}
														<a href="{{ path('app_comment_edit', {'id': comment.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
													{% endif %}
													<!-- Formulaire pour supprimer le commentaire -->
												{% if app.user and app.user == comment.user %}
													<form method="POST" action="{{ path('app_comment_delete', {'id': comment.id}) }}" style="display:inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce commentaire ?');">
														<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ comment.id) }}">
														<button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
													</form>
												{% endif %}
													{% if comment.comments is not empty %}
														{% include 'comment/_replies.html.twig' with {'comment': comment, 'tweet': allTweet} %}
													{% endif %}
												</div>
											{% endfor %}
										</div>
									{% else %}
										<p>Aucun commentaire pour ce tweet.</p>
									{% endif %}
								</div>
								<!-- Formulaire pour ajouter un commentaire -->
								{% if app.user %}
									{% else %}
										<p>Vous devez être connecté pour commenter.</p>
								{% endif %}
								<div class="justify-content-end d-flex">
									<button onclick="window.location.href='{{ path('app_comment_new', { 'tweetId': allTweet.id }) }}'" {% if not app.user %} disabled {% endif %} class="btn border-white fw-bold comment-btn bouton">
										<span>Commenter</span>
										<i class="fa-regular fa-comment"></i>
									</button>
									<button onclick="window.location.href='{{ path('app_tweet_retweet', { id: allTweet.id }) }}'" {% if not app.user %} disabled {% endif %} class="btn btn-outline-secondary fw-bold rt-btn bouton mx-2">
										<span>{{ allTweet.getRetweetCount() }}</span>
										<i class="fa-solid fa-arrows-rotate"></i>
									</button>
									<button class="btn btn-outline-danger fw-bold like-btn bouton" {% if not app.user %} disabled {% endif %} id="like-button-{{ allTweet.id }}" data-tweet-id="{{ allTweet.id }}">
										<div class="like-div-{{ allTweet.id }}">
											<span id="likes-count-{{ allTweet.id }}">{{ allTweet.likes | length }}</span>
											{% if app.user and allTweet.likes|filter(like => like.user.id == app.user.id)|length > 0 %}
												<i class="like-img-{{ allTweet.id }} fas fa-heart"></i>
											{% else %}
												<i class="like-img-{{ allTweet.id }} far fa-heart"></i>
											{% endif %}
										</div>
									</button>
								</div>
							{% endif %}
						</div>
					{% endfor %}
				{% endif %}
			</section>
		</main>

	{% endblock %}
