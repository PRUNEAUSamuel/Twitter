{% extends 'base.html.twig' %}
{% block title %}Connexion{% endblock %}
{% block body %}
    <form method="post" class="container w-50 p-3 text-white">
        <h1 class="h3 my-5 text-center fw-bold">Twitter > X</h1>
        <div class="form-floating my-3">
            <input name="_username" type="text" class="form-control border-secondary bg-black text-white" id="floatingInput" placeholder="" required>
            <label for="floatingInput">Nom d'utilisateur</label>
        </div>
        <div class="form-floating my-3">
            <input name="_password" type="password" class="form-control border-secondary bg-black text-white" id="floatingPassword" placeholder="" required>
            <label for="floatingPassword">Mot de passe</label>
        </div>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <div class="d-grid gap-2 mx-auto my-4">
            {% if error %}
                <div class="text-danger">Nom d'utilisateur ou Mot de passe incorrect.</div>
            {% endif %}
            <button class="btn btn-light text-black fw-bold my-2" type="submit">Se connecter</button>
            <p class="text-center text-white">Vous n'avez pas de compte ?
                <a class="text-decoration-none" href="{{ path('app_register') }}">Inscrivez-vous.</a>
            </p>
        </div>
    </form>
{% endblock %}