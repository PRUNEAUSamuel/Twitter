{% extends 'base.html.twig' %}

{% block title %}Comment{% endblock %}

{% block body %}
    <h1 class="text-white">Comment</h1>

    <table class="table">
        <tbody>
            <tr>
                <th class="text-white">Id</th>
                <td class="text-white">{{ comment.id }}</td>
            </tr>
            <tr>
                <th class="text-white">Content</th>
                <td class="text-white">{{ comment.content }}</td>
            </tr>
            <tr>
                <th class="text-white">CreateAt</th>
                <td class="text-white">{{ comment.createdAt ? comment.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th class="text-white">UpdateAt</th>
                <td class="text-white">{{ comment.updateAt ? comment.updateAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_tweets_index') }}">back</a>

    <a href="{{ path('app_comment_edit', {'id': comment.id}) }}">edit</a>

    {{ include('comment/_delete_form.html.twig') }}
{% endblock %}
