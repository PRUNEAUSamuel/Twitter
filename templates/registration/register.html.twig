<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Register{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        {% endblock %}

        {% block javascripts %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="bg-black text-white">
    {% block body %}
        {% for flash_error in app.flashes('verify_email_error') %}
            <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
        {% endfor %}

        {{ form_errors(registrationForm) }}

        <div class="container w-50 p-3">
            {{ form_start(registrationForm) }}
                <h1 class="h3 my-5 text-center text-white fw-bold">Créer un compte</h1>
                <div class="form-floating my-3">
                    {{ form_widget(registrationForm.username, {'attr': {'class': 'form-control border-secondary bg-black text-white'}}) }}
                </div>
                <div class="form-floating my-3">
                    <input name="_username" type="text" class="form-control border-secondary bg-black text-white" id="floatingInput" placeholder="">
                    <label class="" for="floatingInput">Nom d'utilisateur</label>
                </div>
                <div class="form-floating my-3">
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control border-secondary bg-black text-white', 'id': 'floatingInput'}}) }}
                    {{ form_label(registrationForm.email) }}
                </div>
                {{ form_row(registrationForm.plainPassword, {
                    label: 'Password'
                }) }}
                {{ form_row(registrationForm.agreeTerms) }}

                <button type="submit" class="btn">Register</button>
            {{ form_end(registrationForm) }}
        </div>
        <a href="{{ path('app_login') }}">Login</a>
    {% endblock %}
    </body>
</html>
